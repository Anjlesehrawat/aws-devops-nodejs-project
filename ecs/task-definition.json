{
  "family": "nodejs-devops-task",
  "containerDefinitions": [
    {
      "name": "nodejs-app",
      "image": "REPLACE_WITH_ECR_IMAGE",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}
